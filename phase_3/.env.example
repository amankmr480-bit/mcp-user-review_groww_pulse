# Copy to .env and paste your values:
GROQ_API_KEY=your_groq_api_key_here
ALIAS_EMAIL=your_alias_or_self_email_here

# SMTP settings for sending email drafts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_smtp_username_or_email
SMTP_PASS=your_smtp_app_password
SMTP_FROM=optional_from_email_or_leave_blank

